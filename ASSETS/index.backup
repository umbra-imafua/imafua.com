<script defer>

function shuffle(elems) {

allElems = (function(){
var ret = [], l = elems.length;
while (l--) { ret[ret.length] = elems[l]; }
return ret;
})();

var shuffled = (function(){
    var l = allElems.length, ret = [];
    while (l--) {
        var random = Math.floor(Math.random() * allElems.length),
            randEl = allElems[random].cloneNode(true);
        allElems.splice(random, 1);
        ret[ret.length] = randEl;
    }
    return ret; 
})(), l = elems.length;

while (l--) {
    elems[l].parentNode.insertBefore(shuffled[l], elems[l].nextSibling);
    elems[l].parentNode.removeChild(elems[l]);
}

}

shuffle( document.querySelectorAll('#sectionone > div') )

<script>
  function shuffle(elems) {
  
  allElems = (function(){
  var ret = [], l = elems.length;
  while (l--) { ret[ret.length] = elems[l]; }
  return ret;
  })();

  var shuffled = (function(){
      var l = allElems.length, ret = [];
      while (l--) {
          var random = Math.floor(Math.random() * allElems.length),
              randEl = allElems[random].cloneNode(true);
          allElems.splice(random, 1);
          ret[ret.length] = randEl;
      }
      return ret; 
  })(), l = elems.length;

  while (l--) {
      elems[l].parentNode.insertBefore(shuffled[l], elems[l].nextSibling);
      elems[l].parentNode.removeChild(elems[l]);
  }

  }

  shuffle( document.querySelectorAll('#sectionone > div') )

  var button = document.querySelector('button');
  button.addEventListener('click', function() { shuffle( document.querySelectorAll('#sectionone > div') ) }, false);

</script>


<style>

html {
  color: white;
  background-color: black;
}

main {
  position: absolute;
  left: 0;
  top: 0;
  margin: 0;
  padding: 0;
}


.visually-hidden {
  position: absolute;
  /* Note, you may want to position the checkbox over top the label and set the opacity to zero instead. It can be better for accessibilty on some touch devices for discoverability. */
}

section {
  width: 100%;
  margin: 0;
  padding: 0;
  list-style: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
      user-select: none;
  display: -ms-grid;
  display: grid;
  -ms-grid-columns: (minmax(256px, 1fr))[auto-fill];
      grid-template-columns: repeat(auto-fill, minmax(256px, 1fr));
  /* Play with min-value */
  grid-auto-flow: row dense;
}

section div {
  grid-area: span 1/span 1;
  aspect-ratio: 1/1;
  margin: 1vh;
  background-color: black;
  overflow: hidden;
  border-style: none;
  display: -ms-grid;
  display: grid;
  grid-gap: 0;
  -ms-grid-columns: (minmax(50%, 1fr))[auto-fit];
      grid-template-columns: repeat(auto-fit, minmax(50%, 1fr));
  grid-auto-flow: dense;
}

section div article {
  margin: 3vh;
}

section div img {
  grid-area: span 1/span 1;
  max-width: 100%;
  aspect-ratio: 1/1;
  -o-object-fit: cover;
     object-fit: cover;
  -o-object-position: middle;
     object-position: middle;
}

section div video {
  display: block;
  width: 100%;
  min-height: 100%;
  border-radius: none;
  -o-object-fit: cover;
     object-fit: cover;
  -o-object-position: middle;
     object-position: middle;
}

section div iframe {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-style: none;
  background-color: black;
}

div[rel="xxx"] * {
  -webkit-filter: blur(1.5rem);
          filter: blur(1.5rem);
}

#twoone {
  margin: 1vh;
  grid-area: span 1/span 2;
  aspect-ratio: 2/1;
}

@media (max-width: 640px) {
  #twoone {
    grid-area: span 1/span 1;
  }
}

#twotwo {
  margin: 1vh;
  grid-area: span 2/span 2;
}

@media (max-width: 640px) {
  #twotwo {
    grid-area: span 1/span 1;
  }
}

#threetwo {
  margin: 1vh;
  grid-area: span 2/span 3;
  aspect-ratio: 3/2;
  -ms-grid-columns: (minmax(33.33%, 1fr))[auto-fit];
      grid-template-columns: repeat(auto-fit, minmax(33.33%, 1fr));
}

@media (max-width: 640px) {
  #threetwo {
    grid-area: span 1/span 1;
  }
}
